# Copy to secrets.toml (same folder) and fill in real values.
# Do not commit secrets.toml with production passwords.
#
# Streamlit loads this as st.secrets["postgres"] (table) and st.secrets["postgres"]["host"], etc.

[postgres]
host = "localhost"
port = 5432
user = "postgres"
password = "your_password_here"
database = "farndacred_db"

# Default company for post-login tenant bind (must match public.tenants.company_name):
[tenant]
default_company_name = "Farnda Demo"

# Example: single-tenant default schema (schema-per-tenant — create in PostgreSQL first):
#   CREATE SCHEMA IF NOT EXISTS tenant_default AUTHORIZATION postgres;
#   -- migrate tables into tenant_default or use public for legacy single-tenant
