# Copy to ".env" in this folder (never commit .env). Loaded by config.py into os.environ.
#
# Sources of truth for the SAME Postgres cluster in this repo:
#   1) This file (.env) -> config.get_database_url() -> psycopg2 (auth, dal, loan_management, etc.)
#   2) .streamlit/secrets.toml [postgres] -> st.secrets -> SQLAlchemy tenant sessions (db/tenant_session.py)
# Keep host/user/password/database consistent between them, or use only one path and mirror values.
#
# Database (required if PostgreSQL expects a password)
FARNDACRED_DB_USER='postgres'
FARNDACRED_DB_PASSWORD=''
FARNDACRED_DB_HOST=localhost
FARNDACRED_DB_PORT=5432
FARNDACRED_DB_NAME=''

# Or a single URL (overrides the variables above when set):
# FARNDACRED_DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/lms_db
