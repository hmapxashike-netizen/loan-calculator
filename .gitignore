# Virtual Environment
venv/
ENV/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Databases (We use Postgres, so we ignore the local SQLite file)
db.sqlite3

# Environment variables (Where we will eventually hide passwords)
.env

# Streamlit secrets (use .streamlit/secrets.toml.example as template)
.streamlit/secrets.toml

# Windows system files
Thumbs.db
desktop.ini

# Script output (regenerated by scripts/example_simulation.py)
simulation_results.xlsx
lms_exports/

# Local PostgreSQL dumps (full DB — sensitive; never commit)
dump/*
!dump/.gitkeep

# Local debug traces (large; GitHub rejects blobs > 100 MiB)
debug*.log